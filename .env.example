# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# --- Django ---
SECRET_KEY=generate-a-long-random-secret-key
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,web
CORS_ALLOWED_ORIGINS=http://localhost:3000
ANON_THROTTLE_RATE=60/min

# --- Database ---
# Leave unset to use SQLite in local dev. Docker Compose sets DATABASE_URL for Postgres.
DB_NAME=mentalbot
DB_USER=postgres
DB_PASSWORD=change-me
# DATABASE_URL=postgres://user:password@host:5432/mentalbot

# --- JWT (staff login for admin endpoints) ---
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# --- Email (booking confirmations + contact form) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
CONTACT_RECIPIENT_EMAIL=

# --- Chatbot (RAG) ---
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=mentalbot
OPENAI_CHAT_MODEL=gpt-4o-mini
RAG_RETRIEVER_K=4
RAG_FETCH_K=20
